{
  "name": "docklet-word-viewer",
  "version": "1.0.0",
  "description": "Docklet Word document viewer for Obsidian with local DOCX rendering.",
  "packageManager": "pnpm@10.33.2",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "check": "node ../scripts/run-plugin-task.mjs check"
  },
  "peerDependencies": {
    "obsidian": "*"
  },
  "dependencies": {
    "@docklet/iframe-bridge": "workspace:*",
    "@docklet/obsidian-kit": "workspace:*",
    "@docklet/ooxml": "workspace:*",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@preact/signals-core": "^1.14.1",
    "vite": "^7.2.7",
    "vitest": "^3.2.4",
    "@docklet/styleguide": "workspace:*"
  },
  "private": true,
  "files": [
    "manifest.json",
    "main.js",
    "styles.css",
    "versions.json",
    "resources"
  ]
}
